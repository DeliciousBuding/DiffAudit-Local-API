# Development profile
# Copy to config/dev.env and adjust paths for your machine.
# Use absolute paths and avoid assuming a fixed workspace layout.

DIFFAUDIT_LOCAL_API_HOST=127.0.0.1
DIFFAUDIT_LOCAL_API_PORT=8765
DIFFAUDIT_LOCAL_API_PROJECT_ROOT=C:\path\to\research-project
DIFFAUDIT_LOCAL_API_EXPERIMENTS_ROOT=C:\path\to\research-project\experiments
DIFFAUDIT_LOCAL_API_JOBS_ROOT=C:\path\to\local-api\jobs
DIFFAUDIT_LOCAL_API_GPU_SCHEDULER=C:\path\to\gpu-scheduler.exe
DIFFAUDIT_LOCAL_API_GPU_REQUEST_DOC=C:\path\to\gpu-resource-requests.md
DIFFAUDIT_LOCAL_API_GPU_AGENT_PREFIX=local-api-dev
