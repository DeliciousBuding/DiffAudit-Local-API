# Deploy profile
# Copy to config/deploy.env on the target machine and point the paths to the deployed research data root.

DIFFAUDIT_LOCAL_API_HOST=0.0.0.0
DIFFAUDIT_LOCAL_API_PORT=8765
DIFFAUDIT_LOCAL_API_PROJECT_ROOT=/srv/diffaudit/project
DIFFAUDIT_LOCAL_API_EXPERIMENTS_ROOT=/srv/diffaudit/project/experiments
DIFFAUDIT_LOCAL_API_JOBS_ROOT=/srv/diffaudit/project/workspaces/local-api/jobs
DIFFAUDIT_LOCAL_API_GPU_SCHEDULER=/srv/diffaudit/localops/paper-resource-scheduler/gpu-scheduler
DIFFAUDIT_LOCAL_API_GPU_REQUEST_DOC=/srv/diffaudit/localops/paper-resource-scheduler/gpu-resource-requests.md
DIFFAUDIT_LOCAL_API_GPU_AGENT_PREFIX=local-api-deploy
