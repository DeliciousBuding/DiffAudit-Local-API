# DiffAudit Local API
# Copy this to a local-only env file such as:
# - config/dev.example.env -> config/dev.env
# - config/deploy.example.env -> config/deploy.env

DIFFAUDIT_LOCAL_API_HOST=127.0.0.1
DIFFAUDIT_LOCAL_API_PORT=8765
DIFFAUDIT_LOCAL_API_PROJECT_ROOT=./Project
DIFFAUDIT_LOCAL_API_EXPERIMENTS_ROOT=./Project/experiments
DIFFAUDIT_LOCAL_API_JOBS_ROOT=./Project/workspaces/local-api/jobs
DIFFAUDIT_LOCAL_API_GPU_SCHEDULER=./LocalOps/paper-resource-scheduler/gpu-scheduler.exe
DIFFAUDIT_LOCAL_API_GPU_REQUEST_DOC=./LocalOps/paper-resource-scheduler/gpu-resource-requests.md
DIFFAUDIT_LOCAL_API_GPU_AGENT_PREFIX=local-api
