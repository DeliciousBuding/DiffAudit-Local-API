# DiffAudit Local API
# Copy this to a local-only env file such as:
# - config/dev.example.env -> config/dev.env
# - config/deploy.example.env -> config/deploy.env
# Keep real env files out of git.

DIFFAUDIT_LOCAL_API_HOST=127.0.0.1
DIFFAUDIT_LOCAL_API_PORT=8765
DIFFAUDIT_LOCAL_API_PROJECT_ROOT=/path/to/research-project
DIFFAUDIT_LOCAL_API_EXPERIMENTS_ROOT=/path/to/research-project/experiments
DIFFAUDIT_LOCAL_API_JOBS_ROOT=/path/to/local-api/jobs
DIFFAUDIT_LOCAL_API_GPU_SCHEDULER=/path/to/gpu-scheduler
DIFFAUDIT_LOCAL_API_GPU_REQUEST_DOC=/path/to/gpu-resource-requests.md
DIFFAUDIT_LOCAL_API_GPU_AGENT_PREFIX=local-api
